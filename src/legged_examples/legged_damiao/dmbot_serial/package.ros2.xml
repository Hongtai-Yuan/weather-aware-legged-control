<?xml version="1.0"?>
<package format="3">
  <name>dmbot_serial</name>
  <version>0.0.0</version>
  <description>The dmbot_serial package</description>

  <maintainer email="dm@todo.todo">dm</maintainer>

  <license>TODO</license>

  <!-- Build tool dependency -->
  <buildtool_depend>ament_cmake</buildtool_depend>

  <!-- Build dependencies -->
  <build_depend>rclcpp</build_depend>
  <build_depend>std_msgs</build_depend>

  <!-- Exported build dependencies -->
  <build_export_depend>rclcpp</build_export_depend>
  <build_export_depend>std_msgs</build_export_depend>

  <!-- Execution dependencies -->
  <exec_depend>rclcpp</exec_depend>
  <exec_depend>std_msgs</exec_depend>

  <!-- Export tag can contain other tags -->
  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
